# Personal settings
.claude/settings.local.json
.env

# IDE — user-specific project files (JetBrains)
.idea/
*.iml

# Dashboard server runtime
.sdlc/server.json
.sdlc/server.log

# Working memory + local docs (uncommitted)
sdlc-doc/*

# Generated by npx sdlc init in CONSUMER repos — derived from .sdlc/ source of truth.
# This source repo keeps its own active AGENTS.md, CLAUDE.md, and
# .github/copilot-instructions.md (committed). Consumer-side artifacts below stay ignored.
#
# .claude/ is ignored EXCEPT shared settings.json (hooks for this source repo).
# .claude/settings.local.json (personal overrides) stays ignored.
.claude/*
!.claude/settings.json
.codex/
.github/prompts/
.github/agents/

# Testing runtime artifacts
testing/runs/
testing/logs/
testing/tmp/
testing/tier2/*/Run/
.superpowers/*
